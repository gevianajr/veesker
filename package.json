    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.0.2",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "typescript": "~5.6.3",
