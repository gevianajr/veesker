{
  "name": "veesker-sidecar",
  "version": "0.0.1",
  "private": true,
  "author": {
    "name": "Geraldo Ferreira Viana Júnior",
    "email": "geraldovianajr@veesker.cloud",
    "url": "https://github.com/gevianajr"
  },
  "homepage": "https://veesker.cloud",
  "repository": {
    "type": "git",
    "url": "https://github.com/veesker-cloud/veesker-community-edition.git"
  },
  "bugs": {
    "url": "https://github.com/veesker-cloud/veesker-community-edition/issues"
  },
  "type": "module",
  "scripts": {
    "test": "bun test",
    "_": "--minify breaks oracledb's native binding loader when combined with --compile (NJS-045 at runtime). Do not add it back without re-verifying Thick mode works.",
    "build:win-x64":   "bun build src/index.ts --compile --target=bun-windows-x64  --outfile ../src-tauri/binaries/veesker-sidecar-x86_64-pc-windows-msvc.exe",
    "build:mac-x64":   "bun build src/index.ts --compile --target=bun-darwin-x64   --outfile ../src-tauri/binaries/veesker-sidecar-x86_64-apple-darwin",
    "build:mac-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile ../src-tauri/binaries/veesker-sidecar-aarch64-apple-darwin",
    "build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64    --outfile ../src-tauri/binaries/veesker-sidecar-x86_64-unknown-linux-gnu",
    "build": "bun run build:mac-x64"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "oracledb": "^6.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/oracledb": "^6.10.3",
    "typescript": "^5.6.0"
  }
}
