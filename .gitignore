.DS_Store
node_modules
/build
/.svelte-kit
/package
.env
.env.*
!.env.example
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Rust / Tauri
src-tauri/target/
src-tauri/gen/

# IDE
.idea/
*.swp

# Compiled sidecar binaries (built per-platform via scripts/build-sidecar.sh)
src-tauri/binaries/veesker-sidecar-*
!src-tauri/binaries/.gitkeep
.superpowers/

# NOTE: addons/ folder contains paid add-ons (NOT under Apache 2.0).
# Before turning this repo public, MOVE addons/ to a separate private repo
# (github.com/veesker/veesker-addons) and add `addons/` to this gitignore.
# See docs/ENTERPRISE.md for the open-core boundary.

# Veesker signing keys (NEVER commit)
.veesker/
*-key
*-key.pub
!ssh-keys/
